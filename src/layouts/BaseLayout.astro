---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import {
  defaultLocale,
  getLocaleContent,
  getOtherLocale,
  localeHtmlLang,
  localizePath,
  stripLocalePrefix,
  toAbsoluteUrl,
  type Locale
} from "../lib/i18n";
import { site } from "../lib/site";

interface Props {
  title: string;
  description: string;
  locale: Locale;
  image?: string;
  imageAlt?: string;
  canonical?: string;
  type?: "website" | "article";
  noindex?: boolean;
  switchPath?: string;
}

const { title, description, locale, image, imageAlt, canonical, type = "website", noindex = false, switchPath } = Astro.props;
const copy = getLocaleContent(locale);
const currentPath = Astro.url.pathname;
const pathWithoutLocale = stripLocalePrefix(currentPath);
const otherLocale = getOtherLocale(locale);
const alternatePath = switchPath ?? localizePath(pathWithoutLocale, otherLocale);
const englishPath = locale === "en" ? currentPath : alternatePath;
const canonicalUrl = canonical ?? toAbsoluteUrl(currentPath);
const socialImage = new URL(image ?? site.ogImage, site.domain).toString();
const socialImageAlt = imageAlt ?? copy.ogImageAlt;
const socialImageType = socialImage.endsWith(".png")
  ? "image/png"
  : socialImage.endsWith(".jpg") || socialImage.endsWith(".jpeg")
    ? "image/jpeg"
    : "image/svg+xml";
const structuredData = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "Article" : "WebSite",
  name: title,
  description,
  url: canonicalUrl,
  inLanguage: localeHtmlLang[locale],
  image: socialImage,
  author: {
    "@type": "Person",
    name: site.name,
    url: site.domain,
    sameAs: [site.github, site.linkedin]
  },
  publisher: {
    "@type": "Person",
    name: site.name,
    url: site.domain
  }
};
---

<!doctype html>
<html lang={localeHtmlLang[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="author" content={site.name} />
    <meta name="theme-color" content="#060816" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hrefLang="en" href={toAbsoluteUrl(locale === "en" ? currentPath : alternatePath)} />
    <link rel="alternate" hrefLang="pt-BR" href={toAbsoluteUrl(locale === "pt" ? currentPath : alternatePath)} />
    <link rel="alternate" hrefLang="x-default" href={toAbsoluteUrl(locale === defaultLocale ? currentPath : englishPath)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={locale === "pt" ? "pt_BR" : "en_US"} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:type" content={socialImageType} />
    <meta property="og:image:width" content={String(site.ogImageWidth)} />
    <meta property="og:image:height" content={String(site.ogImageHeight)} />
    <meta property="og:image:alt" content={socialImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:creator" content={site.name} />
    <meta name="format-detection" content="telephone=no" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <script is:inline>
      const preferredLocale = window.localStorage.getItem("preferred-locale");
      if (preferredLocale === "pt" && window.location.pathname === "/") {
        window.location.replace("/pt/");
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">{copy.common.skipToContent}</a>
    <div class="absolute inset-0 -z-10 bg-grid bg-[size:72px_72px] opacity-[0.08]"></div>
    <Header locale={locale} switchPath={alternatePath} />
    <main id="main-content">
      <slot />
    </main>
    <Footer locale={locale} />
    <button
      id="scroll-to-top"
      type="button"
      class="scroll-top-button"
      aria-label={copy.common.backToTop}
      title={copy.common.backToTop}
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
        <path d="m18 15-6-6-6 6"></path>
      </svg>
    </button>
    <script is:inline>
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const header = document.getElementById("site-header");
      const scrollTopButton = document.getElementById("scroll-to-top");

      const syncHeader = () => {
        if (!header) return;
        header.classList.toggle("is-scrolled", window.scrollY > 24);
      };

      const syncScrollTopButton = () => {
        if (!scrollTopButton) return;
        scrollTopButton.classList.toggle("is-visible", window.scrollY > 320);
      };

      const scrollToTop = () => {
        window.scrollTo({
          top: 0,
          behavior: reducedMotion ? "auto" : "smooth"
        });
      };

      syncHeader();
      syncScrollTopButton();
      window.addEventListener("scroll", syncHeader, { passive: true });
      window.addEventListener("scroll", syncScrollTopButton, { passive: true });
      scrollTopButton?.addEventListener("click", scrollToTop);

      if (!reducedMotion && "IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.14, rootMargin: "0px 0px -48px 0px" }
        );

        document.querySelectorAll(".reveal").forEach((element) => observer.observe(element));
      } else {
        document.querySelectorAll(".reveal").forEach((element) => element.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
