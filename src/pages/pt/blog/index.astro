---
import { getCollection } from "astro:content";
import BlogListPage from "../../../components/pages/BlogListPage.astro";
import { getCollectionByLocale } from "../../../lib/i18n";

const posts = getCollectionByLocale(
  (await getCollection("blog")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
  "pt"
);
---

<BlogListPage locale="pt" posts={posts} />
