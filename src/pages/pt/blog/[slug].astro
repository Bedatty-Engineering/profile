---
import { getCollection, render } from "astro:content";
import PostLayout from "../../../layouts/PostLayout.astro";
import { findTranslatedEntry, getSectionPath } from "../../../lib/i18n";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => data.locale === "pt");

  return posts.map((post) => ({
    params: { slug: post.data.pathSlug },
    props: { post }
  }));
}

const allPosts = await getCollection("blog");
const { post } = Astro.props;
const translatedPost = findTranslatedEntry(allPosts, post.data.translationKey, "en");
const switchPath = translatedPost ? `/blog/${translatedPost.data.pathSlug}` : getSectionPath("blog", "en");
const { Content } = await render(post);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  locale="pt"
  switchPath={switchPath}
  date={post.data.date}
  tags={post.data.tags}
>
  <Content />
</PostLayout>
