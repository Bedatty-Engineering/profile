---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { site } from "../lib/site";
---

<BaseLayout title={`Contact | ${site.name}`} description="Contact Lucas Bedatty for cloud platform and DevOps opportunities.">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
    <div class="reveal">
      <SectionIntro
        eyebrow="Contact"
        title="Cloud platform, DevOps and AWS infrastructure conversations."
        copy="Use the channels below for direct contact about platform engineering, infrastructure automation, consulting or full-time roles."
      />
    </div>
    <div class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="reveal space-y-5">
        <p class="copy-muted max-w-xl">
          Direct contact for architecture discussions, consulting work and platform engineering opportunities.
        </p>
        <div class="space-y-4">
          <button
            type="button"
            class="contact-link w-full text-left"
            data-copy-email={site.email}
            aria-describedby="copy-email-status"
          >
            <span class="contact-link-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </span>
            <span class="flex min-w-0 flex-1 flex-col items-start gap-3 sm:flex-row sm:items-center sm:justify-between">
              <span class="contact-link-text">{site.email}</span>
              <span
                class="rounded-md border border-cloud/20 bg-cloud/10 px-2 py-1 font-mono text-[0.65rem] uppercase tracking-[0.18em] text-cloud"
                data-copy-label
              >
                Copy
              </span>
            </span>
          </button>
          <p id="copy-email-status" class="sr-only" aria-live="polite"></p>
          <a href={site.linkedin} target="_blank" rel="noreferrer" class="contact-link" aria-label="Open LinkedIn profile in a new tab">
            <span class="contact-link-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
              </svg>
            </span>
            <span class="contact-link-text">linkedin.com/in/lucas-bedatty</span>
          </a>
          <a href={site.github} target="_blank" rel="noreferrer" class="contact-link" aria-label="Open GitHub profile in a new tab">
            <span class="contact-link-icon">
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
              </svg>
            </span>
            <span class="contact-link-text">github.com/bedatty</span>
          </a>
        </div>
      </div>
      <div class="terminal-window reveal reveal-delay-1">
        <div class="terminal-toolbar">
          <span class="terminal-dot bg-red-500"></span>
          <span class="terminal-dot bg-amber-400"></span>
          <span class="terminal-dot bg-emerald-500"></span>
        </div>
        <div class="space-y-1 overflow-x-auto font-mono text-[0.78rem] leading-7 text-mist sm:text-sm">
          <p class="text-mist/60">// contact.json</p>
          <p>{`{`}</p>
          <p>&nbsp;&nbsp;<span class="text-steel">"name"</span>: <span class="text-aurora">"{site.name}"</span>,</p>
          <p>&nbsp;&nbsp;<span class="text-steel">"title"</span>: <span class="text-aurora">"{site.title}"</span>,</p>
          <p>&nbsp;&nbsp;<span class="text-steel">"location"</span>: <span class="text-aurora">"{site.location}"</span>,</p>
          <p>&nbsp;&nbsp;<span class="text-steel">"languages"</span>: [</p>
          <p>&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-aurora">"Portuguese (Native)"</span>,</p>
          <p>&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-aurora">"English (Working)"</span></p>
          <p>&nbsp;&nbsp;],</p>
          <p>&nbsp;&nbsp;<span class="text-steel">"interests"</span>: [</p>
          <p>&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-aurora">"Cloud Architecture"</span>,</p>
          <p>&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-aurora">"Platform Engineering"</span>,</p>
          <p>&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-aurora">"DevOps Culture"</span>,</p>
          <p>&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-aurora">"Open Source"</span></p>
          <p>&nbsp;&nbsp;],</p>
          <p>&nbsp;&nbsp;<span class="text-steel">"focus"</span>: <span class="text-aurora">"AWS, automation and platform reliability"</span></p>
          <p>{`}`}</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const copyButton = document.querySelector("[data-copy-email]");
    const copyLabel = document.querySelector("[data-copy-label]");
    const copyStatus = document.getElementById("copy-email-status");

    if (copyButton instanceof HTMLButtonElement && copyLabel && copyStatus) {
      const defaultLabel = "Copy";
      let resetTimer;

      copyButton.addEventListener("click", async () => {
        const email = copyButton.dataset.copyEmail;
        if (!email) return;

        try {
          await navigator.clipboard.writeText(email);
          copyLabel.textContent = "Copied";
          copyStatus.textContent = "Email copied to clipboard.";
        } catch {
          copyLabel.textContent = "Failed";
          copyStatus.textContent = "Unable to copy email automatically.";
        }

        window.clearTimeout(resetTimer);
        resetTimer = window.setTimeout(() => {
          copyLabel.textContent = defaultLabel;
        }, 1800);
      });
    }
  </script>
</BaseLayout>
