---
import { getLocaleContent, type Locale } from "../lib/i18n";
import { site } from "../lib/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = getLocaleContent(locale);
---

<footer class="site-footer border-t border-white/10">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-10 text-sm text-mist sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.24em] text-cloud">{copy.footer.status}</p>
      <p class="mt-2">
        {site.name} · {copy.title}
      </p>
    </div>
    <div class="flex flex-wrap gap-4 sm:gap-5">
      <a href={site.linkedin} target="_blank" rel="noreferrer" aria-label={copy.contact.linkedInLabel} class="hover:text-white">LinkedIn</a>
      <a href={`mailto:${site.email}`} class="hover:text-white">{copy.footer.email}</a>
      <a href={site.github} target="_blank" rel="noreferrer" aria-label={copy.contact.githubLabel} class="hover:text-white">GitHub</a>
    </div>
  </div>
</footer>
