---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" }
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="site-header sticky top-0 z-40 border-b border-white/10 bg-ink/75 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 font-mono text-xs font-semibold tracking-[0.08em] text-cloud sm:text-sm">
      <span class="text-aurora">$</span>
      <span>Lucas-Bedatty</span>
      <span class="text-mist/60">~/</span>
      <span class="cursor-blink text-cloud">_</span>
    </a>

    <nav aria-label="Primary navigation" class="grid w-full grid-cols-2 gap-2 text-xs sm:flex sm:w-auto sm:items-center sm:gap-3 sm:text-sm">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            aria-current={currentPath === item.href ? "page" : undefined}
            class:list={[
              "flex min-h-[2.75rem] items-center justify-center rounded-md px-3 py-2 text-center font-mono text-xs uppercase tracking-[0.2em] text-mist hover:bg-cloud/10 hover:text-cloud sm:min-h-0 sm:whitespace-nowrap sm:text-sm",
              currentPath === item.href && "bg-cloud/10 text-cloud"
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
