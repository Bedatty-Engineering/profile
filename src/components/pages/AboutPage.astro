---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionIntro from "../SectionIntro.astro";
import { getLocaleContent, getOtherLocale, localizePath, type Locale } from "../../lib/i18n";
import { site } from "../../lib/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = getLocaleContent(locale);
const switchPath = localizePath("/about", getOtherLocale(locale));
---

<BaseLayout title={`${copy.about.eyebrow} | ${site.name}`} description={copy.description} locale={locale} switchPath={switchPath}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-24">
    <div class="reveal">
      <SectionIntro eyebrow={copy.about.eyebrow} title={copy.about.title} copy={copy.about.copy} />
    </div>
    <div class="reveal reveal-delay-1 mt-8 flex flex-wrap gap-4">
      <a class="button-primary" href="/lucas-bedatty-resume.pdf" download="lucas-bedatty-resume.pdf">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
          <path d="M12 3v12"></path>
          <path d="m7 10 5 5 5-5"></path>
          <path d="M5 21h14"></path>
        </svg>
        <span>{copy.about.resumeLabel}</span>
      </a>
    </div>

    <div class="mt-12 grid gap-6 sm:gap-8 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="shell reveal reveal-mobile-static p-6 sm:p-8">
        <div class="terminal-toolbar">
          <span class="terminal-dot bg-red-500"></span>
          <span class="terminal-dot bg-amber-400"></span>
          <span class="terminal-dot bg-emerald-500"></span>
        </div>
        <p class="mb-6 font-mono text-xs uppercase tracking-[0.24em] text-cloud">{copy.about.summaryLabel}</p>
        <div class="prose-cloud">
          {copy.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>

      <div class="space-y-6">
        <div class="shell reveal reveal-delay-1 p-5 sm:p-6">
          <p class="font-mono text-xs uppercase tracking-[0.25em] text-cloud">{copy.about.profileCard.title}</p>
          <dl class="mt-5 space-y-4 text-sm text-mist">
            <div>
              <dt class="text-xs uppercase tracking-[0.2em] text-slate-400">{copy.about.profileCard.location}</dt>
              <dd class="mt-1 text-white">{site.location}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.2em] text-slate-400">{copy.about.profileCard.titleLabel}</dt>
              <dd class="mt-1 text-white">{copy.title}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.2em] text-slate-400">{copy.about.profileCard.coreFocus}</dt>
              <dd class="mt-1 text-white">{copy.about.profileCard.focusValue}</dd>
            </div>
          </dl>
        </div>
        <div class="grid gap-4 reveal reveal-delay-2 sm:grid-cols-2">
          {copy.about.stats.map((stat) => <div class="stat-card"><div class="stat-number">{stat.number}</div><div class="stat-label">{stat.label}</div></div>)}
        </div>
      </div>
    </div>

    <div class="mt-20">
      <div class="reveal">
        <SectionIntro eyebrow={copy.about.stack.eyebrow} title={copy.about.stack.title} copy={copy.about.stack.copy} />
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {
          copy.skillGroups.map((group, index) => (
            <article class:list={["stack-card reveal", index === 1 && "reveal-delay-1", index === 2 && "reveal-delay-2", index === 3 && "reveal-delay-3"]}>
              <div class="flex items-center gap-4">
                <div class="stack-icon" aria-hidden="true">{group.shortLabel}</div>
                <div>
                  <p class="font-mono text-[0.7rem] uppercase tracking-[0.22em] text-cloud">{copy.common.skillGroup}</p>
                  <h3 class="mt-2 text-xl font-semibold text-white">{group.title}</h3>
                </div>
              </div>
              <p class="stack-items mt-6">{group.items.join(" · ")}</p>
            </article>
          ))
        }
      </div>
    </div>

    <div class="mt-20">
      <div class="reveal">
        <SectionIntro eyebrow={copy.about.experience.eyebrow} title={copy.about.experience.title} copy={copy.about.experience.copy} />
      </div>

      <div class="timeline mt-12">
        {
          copy.experienceTimeline.map((item, index) => (
            <div class:list={["timeline-item reveal", index === 1 && "reveal-delay-1", index === 2 && "reveal-delay-2", index === 3 && "reveal-delay-3"]}>
              <div class="timeline-card shell">
                <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                  <div>
                    <p class="text-xl font-semibold text-white sm:text-2xl">{item.role}</p>
                    <p class="mt-2 font-mono text-sm uppercase tracking-[0.22em] text-cloud">{item.company}</p>
                    <p class="mt-3 text-sm text-mist">{item.location}</p>
                  </div>
                  <span class="timeline-period">{item.period}</span>
                </div>

                {item.summary.length > 0 && (
                  <ul class="mt-6 space-y-3 text-sm leading-7 text-mist">
                    {item.summary.map((point) => <li class="flex gap-3"><span class="font-mono text-cloud">{">"}</span><span>{point}</span></li>)}
                  </ul>
                )}

                <div class="mt-6 flex flex-wrap gap-2">
                  {item.tags.map((tag) => <span class="timeline-tag">{tag}</span>)}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-20 grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
      <div>
        <div class="reveal">
          <SectionIntro eyebrow={copy.about.education.eyebrow} title={copy.about.education.title} copy={copy.about.education.copy} />
        </div>

        <div class="mt-10 grid gap-6">
          {
            copy.educationItems.map((item, index) => (
              <div class:list={["edu-card reveal", index === 1 && "reveal-delay-1"]}>
                <div class="edu-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="h-7 w-7">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                    <path d="M6 12v5c0 1.66 2.69 3 6 3s6-1.34 6-3v-5"></path>
                  </svg>
                </div>
                <p class="text-xl font-semibold text-white">{item.institution}</p>
                <p class="mt-2 text-sm leading-7 text-mist">{item.degree}</p>
                <p class="mt-4 font-mono text-xs uppercase tracking-[0.22em] text-cloud">{item.period}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <div class="reveal">
          <SectionIntro eyebrow={copy.about.certifications.eyebrow} title={copy.about.certifications.title} copy={copy.about.certifications.copy} />
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {
            copy.certificationItems.map((item, index) => (
              <div class:list={["cert-card reveal", index % 3 === 1 && "reveal-delay-1", index % 3 === 2 && "reveal-delay-2"]}>
                <div class="cert-badge">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6">
                    <path d="M12 15l-2 5l1-3h2l1 3l-2-5z"></path>
                    <circle cx="12" cy="9" r="6"></circle>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold leading-6 text-white">{item.name}</p>
                  <p class="mt-1 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-mist">{item.issuer}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
